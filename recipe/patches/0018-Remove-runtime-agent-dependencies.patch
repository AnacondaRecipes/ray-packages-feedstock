Subject: [PATCH] Remove runtime agent dependencies

---
 python/setup.py | 15 ---------------
 1 file changed, 15 deletions(-)

diff --git a/python/setup.py b/python/setup.py
index 3d3e4a1..25f6deb 100644
--- a/python/setup.py
+++ b/python/setup.py
@@ -464,21 +464,6 @@ def build(build_python, build_java, build_cpp, build_redis):
             env=dict(os.environ, CC="gcc"),
         )
 
-        # runtime env agent dependenceis
-        runtime_env_agent_pip_packages = ["aiohttp"]
-        subprocess.check_call(
-            [
-                sys.executable,
-                "-m",
-                "pip",
-                "install",
-                "-q",
-                "--target="
-                + os.path.join(ROOT_DIR, RUNTIME_ENV_AGENT_THIRDPARTY_SUBDIR),
-            ]
-            + runtime_env_agent_pip_packages
-        )
-
     bazel_targets = []
     if build_python:
         bazel_targets.append("//:gen_ray_pkg")
