From 7fe109f8e7d937393afcfaaf7887b0023eea9873 Mon Sep 17 00:00:00 2001
From: Jean-Christophe Morin <jcmorin@anaconda.com>
Date: Fri, 27 Feb 2026 02:16:48 -0800
Subject: [PATCH] Don't build redis with jemalloc on linux-aarch64 to avoid a 
 mysterious linking error:

LINK redis-server
defrag.o:defrag.c:function activeDefragAlloc: error: undefined reference to 'je_get_defrag_hint'
---
 bazel/redis.BUILD | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/bazel/redis.BUILD b/bazel/redis.BUILD
index 15f31b9..fd1cc06 100644
--- a/bazel/redis.BUILD
+++ b/bazel/redis.BUILD
@@ -21,6 +21,7 @@ make(
     name = "redis",
     args = [
         "BUILD_TLS=yes",
+        "USE_JEMALLOC=no",
         "-s",
     ],
     copts = [
@@ -29,6 +30,9 @@ make(
         "-Wno-empty-body",
         "-fPIC",
     ],
+    env = {
+        "PATH": "$$BUILD_PREFIX/bin:$$PATH",
+    },
     visibility = ["//visibility:public"],
     lib_source = ":all_srcs",
     deps = [
-- 
2.39.3 (Apple Git-146)

